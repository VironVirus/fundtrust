APP_NAME=Fundtrust
APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters

APPS_SCRIPT_WEB_APP_URL=https://script.google.com/macros/s/your-web-app-id/exec
APPS_SCRIPT_SHARED_SECRET=replace-with-a-shared-secret-you-set-in-apps-script

ADMIN_LOGIN=admin
ADMIN_PASSWORD_HASH=$2b$10$replace_with_bcrypt_hash
ADMIN_EMAIL=admin@fundtrust.app

# Choose smtp, resend, or log for local development preview
EMAIL_PROVIDER=log
WHATSAPP_PROVIDER=log
WHATSAPP_API_VERSION=v23.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_PHONE=
WHATSAPP_TEMPLATE_LANGUAGE=en
WHATSAPP_TEMPLATE_REGISTRATION=
WHATSAPP_TEMPLATE_DEPOSIT=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Fundtrust <no-reply@fundtrust.app>"

RESEND_API_KEY=
RESEND_FROM="Fundtrust <no-reply@fundtrust.app>"
